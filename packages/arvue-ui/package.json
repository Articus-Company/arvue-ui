{
    "name": "arvue-ui",
    "version": "0.9.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Articus-Company/arvue-ui.git",
        "directory": "packages/arvue-ui"
    },
    "scripts": {
        "build": "pnpm type-check && pnpm build-only",
        "build-only": "tsdown",
        "type-check": "vue-tsc -p tsconfig.build.json --noEmit",
        "watch": "tsdown --watch",
        "pub:release": "pnpm publish --no-git-checks --access public"
    },
    "keywords": [
        "ui",
        "vue",
        "components",
        "webasyst"
    ],
    "author": "Articus-Company",
    "license": "MIT",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js"
        },
        "./all.css": "./dist/all.css",
        "./package.json": "./package.json"
    },
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "src",
        "dist",
        "!src/**/*.story.vue",
        "!src/**/*.test.*",
        "!src/**/_*.vue",
        "!src/**/__snapshots__",
        "!src/**/stories",
        "!src/**/story"
    ],
    "packageManager": "pnpm@10.26.1",
    "dependencies": {
        "@vueuse/core": "^14.3.0",
        "class-variance-authority": "^0.7.1",
        "motion-v": "^2.2.1",
        "reka-ui": "^2.9.8",
        "vaul-vue": "^0.4.1",
        "vue-sonner": "^2.0.9"
    },
    "devDependencies": {
        "@microsoft/api-extractor": "^7.58.7",
        "@tsconfig/node24": "^24.0.4",
        "@tsdown/css": "^0.22.0",
        "@types/node": "^24.10.9",
        "@vitejs/plugin-vue": "^6.0.6",
        "@vue/tsconfig": "^0.9.1",
        "clsx": "^2.1.1",
        "jiti": "^2.6.1",
        "postcss-import": "^16.1.1",
        "tsdown": "^0.22.0",
        "tsx": "^4.21.0",
        "unplugin-vue": "^7.2.0",
        "vue-tsc": "^3.2.8"
    },
    "peerDependencies": {
        "vue": "^3.5.33"
    }
}
